# Render / production — MongoDB for app data + optional Redis for sessions/cache/queue.

# Required on Render: APP_KEY, APP_URL, MONGODB_URI, MONGODB_DATABASE,

# SANCTUM_STATEFUL_DOMAINS (hostname only, no scheme — match your APP_URL host).



APP_ENV=production

APP_DEBUG=false

APP_KEY=

APP_URL=https://your-service.onrender.com



# Fail-closed Eloquent when TenantContext is missing (recommended for production).

STRICT_TENANT_SCOPING=true



# --- Central platform admin (developers only) ---

# Enter these on the property sign-in screen to open the platform control panel.

CENTRAL_ADMIN_USERNAME=madyawph_platform

CENTRAL_ADMIN_PASSWORD=

CENTRAL_ADMIN_EMAIL=platform@madyawph.local

PLATFORM_MEMBER_MONTHLY_FEE=300



# --- MongoDB Atlas (required) ---

DB_CONNECTION=mongodb

MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/?retryWrites=true&w=majority&appName=HotelHMS

MONGODB_DATABASE=hotel_hms



# --- Sessions ---

# Use redis ONLY after Render Redis is linked and REDIS_URL is set (see below).

# With SESSION_DRIVER=redis + empty URL + REDIS_HOST=127.0.0.1 you get 500 (no Redis on localhost).

# file = safe until Redis env is correct; redis = multiple web instances / sticky sessions.

SESSION_DRIVER=file

SESSION_LIFETIME=120

SESSION_SECURE_COOKIE=true

SESSION_SAME_SITE=lax

# Laravel Redis connection name from config/database.php (default connection).

# SESSION_CONNECTION=default



# Queue / cache (optional upgrade when Redis is attached)

QUEUE_CONNECTION=sync

QUEUE_FAILED_DRIVER=null

CACHE_STORE=file



# =============================================================================

# Uploads — Render persistent disk (REQUIRED for images to survive redeploys)

# =============================================================================

# Without a persistent disk, room photos / hotel banners / QR codes are stored inside

# the container filesystem and are DELETED on every deploy.

#

# Option A — Blueprint (recommended): deploy with render.yaml in this repo.

#   It attaches a 10 GB disk at /var/data/uploads automatically.

#

# Option B — Manual in Render dashboard → your web service → Disks → Add disk:

#   Name: uploads

#   Mount path: /var/data/uploads

#   Size: 10 GB (or more)

#

# Then set BOTH variables below to match the mount path (do NOT use S3):

FILESYSTEM_UPLOAD_DISK=uploads

FILESYSTEM_UPLOAD_ROOT=/var/data/uploads

#

# On each container start, scripts/render-start.sh runs:

#   php artisan uploads:ensure-persistent

# which creates upload folders on the disk and copies any legacy files from

# storage/app/public into the persistent volume (safe to run repeatedly).

#

# Images are served via GET /api/v1/chat/media?f=rooms/... (no S3 required).



# =============================================================================

# Redis — attach managed Redis in your host dashboard, then fill ONE style:

#

# A) Single URL (common on Render/Railway/Fly):

#    REDIS_URL=redis://default:PASSWORD@HOST:6379

#    or TLS: rediss://...

#

# B) Discrete vars (if your provider splits host/password):

#    REDIS_HOST=xxx.redis.cache.amazonaws.com

#    REDIS_PASSWORD=secret

#    REDIS_PORT=6379

#    REDIS_USERNAME=default

#

# Laravel merges REDIS_URL with REDIS_HOST / REDIS_PASSWORD when both set — prefer URL when offered.

#

# Enable Redis usage after variables work:

#    SESSION_DRIVER=redis

#    CACHE_STORE=redis

#    QUEUE_CONNECTION=redis

#

# EXTENSIONS: phpredis needs ext-redis. This repo ships predis + Dockerfile sets REDIS_CLIENT=predis.

REDIS_CLIENT=predis

# Use REDIS_URL **or** leave it empty and set REDIS_HOST + REDIS_PORT + REDIS_PASSWORD (+ REDIS_USERNAME if required).

REDIS_URL=

REDIS_HOST=

REDIS_USERNAME=

REDIS_PASSWORD=

REDIS_PORT=6379

REDIS_DB=0

# If your Redis plan only allows DB 0, set REDIS_CACHE_DB=0 as well (cache shares DB 0 with a key prefix).

REDIS_CACHE_DB=1



SANCTUM_STATEFUL_DOMAINS=your-service.onrender.com



# Flutter / API clients use HTTPS + Bearer tokens; no Vite frontend.

# CORS only matters for browser tools hitting the API from another origin.

# CORS_ALLOWED_ORIGINS=https://your-service.onrender.com



APP_TRUSTED_ORIGIN_PREFIXES=


