# Render / production — MongoDB only (no SQL).
# Required on Render: APP_KEY, APP_URL, MONGODB_URI, MONGODB_DATABASE,
# SANCTUM_STATEFUL_DOMAINS (hostname only, no scheme — match your APP_URL host).

APP_ENV=production
APP_DEBUG=false
APP_KEY=
APP_URL=https://your-service.onrender.com

# --- MongoDB Atlas (required) ---
DB_CONNECTION=mongodb
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/?retryWrites=true&w=majority&appName=HotelHMS
MONGODB_DATABASE=hotel_hms

# Sessions: compatible with MongoDB. Use `file` for dev / one server, or `redis` when you have
# multiple app instances. `database` session driver needs SQL, not your Mongo app DB.
# `file` fails across scaled Render web services; Redis is the usual production fix.
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax

# Queue / cache: use Redis with sessions for scale, or keep sync + file for small deploys.
QUEUE_CONNECTION=sync
QUEUE_FAILED_DRIVER=null
CACHE_STORE=file

# --- Redis (optional; add "Redis" in Render dashboard, then set vars below) ---
# MongoDB is unchanged: Redis is only for sessions/cache/queue, not for User/Hotel data.
# Render injects REDIS_URL for the private Redis service; Laravel reads it in config/database.php.
# PHP needs the `redis` extension (Render’s PHP runtimes include it, or use `REDIS_CLIENT=predis`
# and `composer require predis/predis` if you standardize on Predis instead of PhpRedis).
#
# Example when using Redis for sessions + cache:
# SESSION_DRIVER=redis
# CACHE_STORE=redis
# REDIS_URL=redis://red-xxxxx:6379
# REDIS_PASSWORD=...   # only if your provider sets password separately from URL
#
# Keep SESSION_CONNECTION unset unless you define a custom Redis connection name.

SANCTUM_STATEFUL_DOMAINS=your-service.onrender.com
VITE_API_BASE_URL=https://your-service.onrender.com

APP_TRUSTED_ORIGIN_PREFIXES=
