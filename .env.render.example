# Render / production — MongoDB only (no SQL).
# Required on Render: APP_KEY, APP_URL, MONGODB_URI, MONGODB_DATABASE,
# SANCTUM_STATEFUL_DOMAINS (hostname only, no scheme — match your APP_URL host).

APP_ENV=production
APP_DEBUG=false
APP_KEY=
APP_URL=https://your-service.onrender.com

# --- MongoDB Atlas (required) ---
DB_CONNECTION=mongodb
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/?retryWrites=true&w=majority&appName=HotelHMS
MONGODB_DATABASE=hotel_hms

# Sessions: Laravel's SESSION_DRIVER=database needs a SQL `sessions` table.
# With MongoDB-only, use `file` (simplest; sessions reset if the dyno disk is wiped) or Redis (best).
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax

# Queue / cache: `database` drivers need SQL job/cache tables. Use sync + file, or Redis for scale.
QUEUE_CONNECTION=sync
QUEUE_FAILED_DRIVER=null
CACHE_STORE=file

# Optional: attach Render Redis and switch to:
# SESSION_DRIVER=redis
# CACHE_STORE=redis
# QUEUE_CONNECTION=redis
# REDIS_URL=redis://...

SANCTUM_STATEFUL_DOMAINS=your-service.onrender.com
VITE_API_BASE_URL=https://your-service.onrender.com

APP_TRUSTED_ORIGIN_PREFIXES=
