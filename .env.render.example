# CRITICAL .env Settings for Render Deployment
# This prevents the navigation loop issue on stateless Render infrastructure

# Session Storage - MUST use 'database' on Render (not 'file' - ephemeral storage)
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_EXPIRE_ON_CLOSE=false
SESSION_SECURE_COOKIE=true

# App Configuration
APP_ENV=production
APP_DEBUG=false
APP_URL=https://your-render-domain.onrender.com
FRONTEND_URL=https://your-render-domain.onrender.com

# Database Configuration (MongoDB for this project)
DB_CONNECTION=mongodb
MONGODB_URI=mongodb+srv://DB_USER:DB_PASSWORD@cluster0.xxxxx.mongodb.net/hotel_hms?retryWrites=true&w=majority&appName=HotelHMS
MONGODB_DATABASE=hotel_hms

# Render-specific configurations
# Trust all proxy headers since Render uses proxies
TRUSTEDPROXY_HEADERS=Request::HEADER_X_FORWARDED_FOR|Request::HEADER_X_FORWARDED_HOST|Request::HEADER_X_FORWARDED_PORT|Request::HEADER_X_FORWARDED_PROTO|Request::HEADER_X_FORWARDED_AWS_ELB

# API & CORS
VITE_API_BASE_URL=https://your-render-domain.onrender.com
SANCTUM_STATEFUL_DOMAINS=your-render-domain.onrender.com
CORS_ALLOWED_ORIGINS=https://your-render-domain.onrender.com

# Mail Configuration
MAIL_MAILER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=your_mailtrap_user
MAIL_PASSWORD=your_mailtrap_password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@madyaw.onrender.com
MAIL_FROM_NAME="Madyaw Hotel HMS"

# SMS Configuration (if using Twilio or similar)
SMS_SERVICE=twilio
TWILIO_ACCOUNT_SID=your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# Payment Gateway (PayMongo)
PAYMONGO_PUBLIC_KEY=your_public_key
PAYMONGO_SECRET=your_secret_key

# Queue Configuration - Use 'database' instead of 'sync' for better performance
QUEUE_CONNECTION=database

# Cache Configuration
CACHE_DRIVER=database
# CACHE_DRIVER=redis (if using Redis)
# REDIS_HOST=your-redis-host
# REDIS_PASSWORD=your-redis-password
# REDIS_PORT=6379

# Logging
LOG_CHANNEL=stack
LOG_LEVEL=error
