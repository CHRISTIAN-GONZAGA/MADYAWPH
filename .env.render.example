# Render / production — MongoDB for app data + optional Redis for sessions/cache/queue.
# Required on Render: APP_KEY, APP_URL, MONGODB_URI, MONGODB_DATABASE,
# SANCTUM_STATEFUL_DOMAINS (hostname only, no scheme — match your APP_URL host).

APP_ENV=production
APP_DEBUG=false
APP_KEY=
APP_URL=https://your-service.onrender.com

# --- MongoDB Atlas (required) ---
DB_CONNECTION=mongodb
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/?retryWrites=true&w=majority&appName=HotelHMS
MONGODB_DATABASE=hotel_hms

# --- Sessions ---
# file = OK single instance; redis = shared sessions across scaled/multiple web instances.
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax
# When SESSION_DRIVER=redis, Laravel uses config/database.php redis connections (see below).
# SESSION_CONNECTION=default

# Queue / cache (optional upgrade when Redis is attached)
QUEUE_CONNECTION=sync
QUEUE_FAILED_DRIVER=null
CACHE_STORE=file

# =============================================================================
# Redis — attach managed Redis in your host dashboard, then fill ONE style:
#
# A) Single URL (common on Render/Railway/Fly):
#    REDIS_URL=redis://default:PASSWORD@HOST:6379
#    or TLS: rediss://...
#
# B) Discrete vars (if your provider splits host/password):
#    REDIS_HOST=xxx.redis.cache.amazonaws.com
#    REDIS_PASSWORD=secret
#    REDIS_PORT=6379
#    REDIS_USERNAME=default
#
# Laravel merges REDIS_URL with REDIS_HOST / REDIS_PASSWORD when both set — prefer URL when offered.
#
# Enable Redis usage after variables work:
#    SESSION_DRIVER=redis
#    CACHE_STORE=redis
#    QUEUE_CONNECTION=redis
#
# EXTENSIONS: phpredis needs ext-redis. This repo ships predis + Dockerfile sets REDIS_CLIENT=predis.
REDIS_CLIENT=predis
REDIS_URL=
REDIS_HOST=127.0.0.1
REDIS_USERNAME=
REDIS_PASSWORD=
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1

SANCTUM_STATEFUL_DOMAINS=your-service.onrender.com
VITE_API_BASE_URL=https://your-service.onrender.com

APP_TRUSTED_ORIGIN_PREFIXES=
