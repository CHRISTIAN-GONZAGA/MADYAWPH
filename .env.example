# Copy to .env and set values. This app uses MongoDB as the primary database (mongodb/laravel-mongodb).

APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# When true, BelongsToHotel models return no rows if no tenant was bound (production hardening).
STRICT_TENANT_SCOPING=true

# --- MongoDB (required) ---
# Atlas example: mongodb+srv://USER:PASS@cluster.mongodb.net/?retryWrites=true&w=majority
# Local example: mongodb://127.0.0.1:27017
DB_CONNECTION=mongodb
MONGODB_URI=mongodb://127.0.0.1:27017
MONGODB_DATABASE=hotel_hms

# Laravel's "database" session/cache/queue drivers expect SQL tables — use file/redis/array with MongoDB-only.
SESSION_DRIVER=file
SESSION_LIFETIME=120

QUEUE_CONNECTION=sync
# Optional: database-uuids only if you use SQL failed_jobs (not Mongo-only).
QUEUE_FAILED_DRIVER=null

CACHE_STORE=file

# --- Uploads (room/category/chat images) ---
# Local dev uses storage/app/public. Render: attach persistent disk + set FILESYSTEM_UPLOAD_ROOT.
FILESYSTEM_UPLOAD_DISK=uploads
# FILESYSTEM_UPLOAD_ROOT=/var/data/uploads
# Optional S3 instead: FILESYSTEM_UPLOAD_DISK=s3 + AWS_BUCKET=...

# --- Redis (sessions / cache / queues — optional; MongoDB remains your app DB) ---
REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1

# Sanctum / SPA (adjust host for production)
SANCTUM_STATEFUL_DOMAINS=localhost,127.0.0.1

# Optional: secret for POST /api/v1/integrations/run-test (header X-Integrations-Test-Token)
INTEGRATIONS_TEST_TOKEN=

# =============================================================================
# MESSAGING — master switches (keep false until SES/SMS are ready)
# =============================================================================
MESSAGING_EMAIL_ENABLED=false
MESSAGING_SMS_ENABLED=false

# =============================================================================
# EMAIL — Mailjet Send API v3.1 (OTP, password reset, guest check-in welcome)
# =============================================================================
# Uses HTTPS https://api.mailjet.com/v3.1/send (works on Render; SMTP often blocked).
# 1) Mailjet → Account settings → API keys (Public + Private)
# 2) Mailjet → Sender addresses / domains → verify MAIL_FROM_ADDRESS
# 3) Set MESSAGING_EMAIL_ENABLED=true (above)
#
MAIL_MAILER=mailjet
MAILJET_APIKEY_PUBLIC=your_mailjet_api_key
MAILJET_APIKEY_PRIVATE=your_mailjet_secret_key
# Or reuse the same keys as:
# MAIL_USERNAME=your_mailjet_api_key
# MAIL_PASSWORD=your_mailjet_secret_key
MAIL_FROM_ADDRESS=noreply@your-verified-domain.com
MAIL_FROM_NAME="${APP_NAME}"
# Optional OTP expiry (minutes)
# EMAIL_OTP_REGISTRATION_TTL_MINUTES=10
# EMAIL_OTP_RESET_TTL_MINUTES=30
#
# Local dev without Mailjet: MAIL_MAILER=log
#
# Legacy SMTP (not recommended on Render):
# MAIL_MAILER=smtp
# MAIL_HOST=in-v3.mailjet.com
# MAIL_PORT=587
# MAIL_USERNAME=...
# MAIL_PASSWORD=...
# MAIL_SCHEME=tls

# =============================================================================
# SMS — Semaphore (legacy / optional — hotel registration now uses email)
# =============================================================================
# Get your API key: https://semaphore.co → Account → API
# Register a sender name in the Semaphore dashboard (shown as SEMAPHORE_SENDER_NAME).
#
# Placeholders — replace with your real keys:
SEMAPHORE_API_KEY=your_semaphore_api_key_here
# Must match an approved sender in Semaphore (often "SEMAPHORE" until custom name is approved).
SEMAPHORE_SENDER_NAME=SEMAPHORE
# Optional override (default https://api.semaphore.co):
# SEMAPHORE_BASE_URL=https://api.semaphore.co

# --- Twilio SMS (optional fallback if Semaphore is not set) ---
TWILIO_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# --- Generic SMS HTTP API (optional third fallback) ---
SMS_API_BASE_URL=
SMS_API_KEY=
SMS_API_PATH=/messages
SMS_SENDER=MADYAW

# =============================================================================
# PAYMENTS — Xendit (recommended for GCash / PayMaya wallet recharge)
# =============================================================================
# Dashboard: https://dashboard.xendit.co
# 1) Developers → API Keys → copy Secret API Key (test or live)
# 2) Settings → Webhooks → Invoices → URL: {APP_URL}/webhooks/xendit
#    Copy the verification / callback token into XENDIT_WEBHOOK_TOKEN
# 3) Enable GCASH and PAYMAYA payment channels for Invoices
#
# Placeholders — replace with your real keys:
XENDIT_SECRET_KEY=xnd_development_your_secret_key_here
XENDIT_WEBHOOK_TOKEN=your_xendit_webhook_verification_token_here
XENDIT_MIN_RECHARGE_AMOUNT=1
XENDIT_INVOICE_DURATION_SECONDS=86400

# --- PayMongo (optional fallback if Xendit is not set) ---
PAYMONGO_SECRET_KEY=
PAYMONGO_PUBLIC_KEY=
PAYMONGO_WEBHOOK_SECRET=
# Webhook URL: POST {APP_URL}/webhooks/paymongo

# --- Custom payment HTTP API (optional third fallback) ---
PAYMENTS_API_BASE_URL=
PAYMENTS_API_KEY=
