# Copy to .env and set values. This app uses MongoDB as the primary database (mongodb/laravel-mongodb).

APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# When true, BelongsToHotel models return no rows if no tenant was bound (production hardening).
STRICT_TENANT_SCOPING=false

# --- MongoDB (required) ---
# Atlas example: mongodb+srv://USER:PASS@cluster.mongodb.net/?retryWrites=true&w=majority
# Local example: mongodb://127.0.0.1:27017
DB_CONNECTION=mongodb
MONGODB_URI=mongodb://127.0.0.1:27017
MONGODB_DATABASE=hotel_hms

# Laravel's "database" session/cache/queue drivers expect SQL tables — use file/redis/array with MongoDB-only.
SESSION_DRIVER=file
SESSION_LIFETIME=120

QUEUE_CONNECTION=sync
# Optional: database-uuids only if you use SQL failed_jobs (not Mongo-only).
QUEUE_FAILED_DRIVER=null

CACHE_STORE=file

# --- Redis (sessions / cache / queues — optional; MongoDB remains your app DB) ---
REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1

# Sanctum / SPA (adjust host for production)
SANCTUM_STATEFUL_DOMAINS=localhost,127.0.0.1

# =============================================================================
# SMS — Semaphore (recommended for Philippines)
# =============================================================================
# Get your API key: https://semaphore.co → Account → API
# Register a sender name in the Semaphore dashboard (shown as SEMAPHORE_SENDER_NAME).
#
# Placeholders — replace with your real keys:
SEMAPHORE_API_KEY=your_semaphore_api_key_here
SEMAPHORE_SENDER_NAME=MADYAW
# Optional override (default https://api.semaphore.co):
# SEMAPHORE_BASE_URL=https://api.semaphore.co

# --- Twilio SMS (optional fallback if Semaphore is not set) ---
TWILIO_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# --- Generic SMS HTTP API (optional third fallback) ---
SMS_API_BASE_URL=
SMS_API_KEY=
SMS_API_PATH=/messages
SMS_SENDER=MADYAW

# =============================================================================
# PAYMENTS — Xendit (recommended for GCash / PayMaya wallet recharge)
# =============================================================================
# Dashboard: https://dashboard.xendit.co
# 1) Developers → API Keys → copy Secret API Key (test or live)
# 2) Settings → Webhooks → Invoices → URL: {APP_URL}/webhooks/xendit
#    Copy the verification / callback token into XENDIT_WEBHOOK_TOKEN
# 3) Enable GCASH and PAYMAYA payment channels for Invoices
#
# Placeholders — replace with your real keys:
XENDIT_SECRET_KEY=xnd_development_your_secret_key_here
XENDIT_WEBHOOK_TOKEN=your_xendit_webhook_verification_token_here
XENDIT_MIN_RECHARGE_AMOUNT=1
XENDIT_INVOICE_DURATION_SECONDS=86400

# --- PayMongo (optional fallback if Xendit is not set) ---
PAYMONGO_SECRET_KEY=
PAYMONGO_PUBLIC_KEY=
PAYMONGO_WEBHOOK_SECRET=
# Webhook URL: POST {APP_URL}/webhooks/paymongo

# --- Custom payment HTTP API (optional third fallback) ---
PAYMENTS_API_BASE_URL=
PAYMENTS_API_KEY=
