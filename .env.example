# Copy to .env and set values. This app uses MongoDB as the primary database (mongodb/laravel-mongodb).

APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# When true, BelongsToHotel models return no rows if no tenant was bound (production hardening).
STRICT_TENANT_SCOPING=false

# --- MongoDB (required) ---
# Atlas example: mongodb+srv://USER:PASS@cluster.mongodb.net/?retryWrites=true&w=majority
# Local example: mongodb://127.0.0.1:27017
DB_CONNECTION=mongodb
MONGODB_URI=mongodb://127.0.0.1:27017
MONGODB_DATABASE=hotel_hms

# Laravel's "database" session/cache/queue drivers expect SQL tables — use file/redis/array with MongoDB-only.
SESSION_DRIVER=file
SESSION_LIFETIME=120

QUEUE_CONNECTION=sync
# Optional: database-uuids only if you use SQL failed_jobs (not Mongo-only).
QUEUE_FAILED_DRIVER=null

CACHE_STORE=file

# --- Redis (sessions / cache / queues — optional; MongoDB remains your app DB) ---
# Use either REDIS_URL (Railway, Render, Redis Cloud often give one URL) OR host/port/password below.
# REDIS_CLIENT: phpredis requires PHP redis extension; predis works everywhere (composer package).
# SESSION_DRIVER=redis needs REDIS_* configured. Dockerfile sets REDIS_CLIENT=predis.
REDIS_CLIENT=predis
# REDIS_URL=redis://:password@127.0.0.1:6379
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1
# Optional named Redis DB index for sessions if you split keys (defaults use connection "default").
# SESSION_CONNECTION=default

# Sanctum / SPA (adjust host for production)
SANCTUM_STATEFUL_DOMAINS=localhost,127.0.0.1

# --- Twilio SMS (recommended for production) ---
# Use E.164 format for phone numbers (e.g. +63917xxxxxxx)
TWILIO_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
