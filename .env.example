APP_NAME=Laravel
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://your-domain.example
FRONTEND_URL=https://your-domain.example

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# =============================================================================
# DATABASE (MongoDB Atlas — required for the app to run; not a REST API)
# =============================================================================
# Replace USER, PASSWORD, CLUSTER_HOST with your Atlas values. URL-encode special
# characters in the password. This string is read by config/database.php.
DB_CONNECTION=mongodb
DB_DATABASE=hotel_hms
MONGODB_DATABASE=hotel_hms
MONGODB_URI="mongodb+srv://USER:PASSWORD@CLUSTER_HOST/hotel_hms?retryWrites=true&w=majority&appName=HotelHMS"

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax
SANCTUM_STATEFUL_DOMAINS=your-domain.example,www.your-domain.example

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

CACHE_STORE=file

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# =============================================================================
# EXTERNAL APIs THIS APP CALLS (third-party HTTP services)
# =============================================================================
#
# You need ONE working SMS integration for production (pick Twilio OR custom).
#   Used by: API OTP (/api/otp/send), password reset SMS, checkout SMS reminders.
#   Code: App\Services\SmsService → config/services.php keys below.
#
# Payments — OPTIONAL (admin credit recharge).
#   Primary: PayMongo (PAYMONGO_SECRET_KEY) → GCash / PayMaya checkout + webhook credits hotel.
#   Alternate: custom POST gateway (PAYMENTS_*). If neither is set → local sandbox (instant test credits).
#
# AWS is OPTIONAL (only if FILESYSTEM_DISK=s3).
#   Code: config/filesystems.php → AWS_* below.
#
# =============================================================================

# -----------------------------------------------------------------------------
# SMS — REQUIRED for real text delivery (choose ONE option)
# -----------------------------------------------------------------------------
#
# OPTION A — Twilio (recommended; matches Twilio’s REST API exactly)
#   Set ALL of: TWILIO_SID, TWILIO_TOKEN (or TWILIO_AUTH_TOKEN), TWILIO_FROM (or TWILIO_FROM_NUMBER).
#   TWILIO_SID = Account SID from Twilio Console (starts with AC…).
#   TWILIO_TOKEN = Auth Token from Twilio Console.
#   TWILIO_FROM = your Twilio SMS-capable number in E.164, e.g. +639171234567.
#   When these are set, the app uses Twilio and ignores SMS_API_*.
#
TWILIO_SID=
TWILIO_TOKEN=
TWILIO_FROM=
# Legacy names (optional): same values as TOKEN / FROM if you prefer these env names.
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
#
# OPTION B — Custom SMS HTTP API (only if Twilio above is NOT fully configured)
#   Your server must expose POST {SMS_API_BASE_URL}/messages
#   Headers: Authorization: Bearer <SMS_API_KEY>, Content-Type: application/json
#   JSON body: { "to": "<phone>", "message": "<text>", "sender": "<SMS_SENDER>" }
#   Must respond HTTP 2xx on success (same check Laravel Http uses everywhere).
#
SMS_API_BASE_URL=
SMS_API_KEY=
SMS_SENDER=MADYAW

# -----------------------------------------------------------------------------
# PAYMENTS — PayMongo (recommended on Railway)
# -----------------------------------------------------------------------------
# Set PAYMONGO_SECRET_KEY (sk_test_… or sk_live_…) from the PayMongo Dashboard.
# Recharge flow:
#   1) Admin picks GCash or PayMaya and amount (minimum PHP 100 when PayMongo is enabled).
#   2) App creates a PayMongo Source and returns a checkout URL → browser redirects to PayMongo.
#   3) After the customer pays, PayMongo sends webhook payment.paid to your public URL:
#        POST https://YOUR_RAILWAY_DOMAIN/webhooks/paymongo
#      In PayMongo Dashboard → Webhooks, add that URL and subscribe to payment.paid (and payment.failed if you like).
#      Copy the webhook signing secret into PAYMONGO_WEBHOOK_SECRET (whsk_…).
#   4) This app credits the hotel balance from payment metadata (hotel_id, amount_php).
#
# PAYMONGO_PUBLIC_KEY (pk_…) is optional for future client-side flows; not required for this server-only path.
#
PAYMONGO_SECRET_KEY=
PAYMONGO_PUBLIC_KEY=
PAYMONGO_WEBHOOK_SECRET=
#
# Optional — custom gateway instead of calling PayMongo from this app (advanced).
# If PAYMONGO_SECRET_KEY is set, it wins and PAYMENTS_* are ignored.
# POST {PAYMENTS_API_BASE_URL}/payments/charge with Bearer PAYMENTS_API_KEY (same contract as before).
#
PAYMENTS_API_BASE_URL=
PAYMENTS_API_KEY=

# =============================================================================
# Laravel mail (not used for OTP / password reset — those use SMS only)
# =============================================================================
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# =============================================================================
# AWS S3 — OPTIONAL (only when FILESYSTEM_DISK=s3)
# =============================================================================
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
VITE_API_BASE_URL="${APP_URL}"
CORS_ALLOWED_ORIGINS=https://your-domain.example,https://www.your-domain.example
